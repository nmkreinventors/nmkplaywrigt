<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Amazon Cross Browser Suite" verbose="3" parallel="tests" thread-count="3">

<!--    Chrome-->
    <test name="Chrome tests" preserve-order="false">
        <parameter name="browser" value="chrome"/>
        <classes>
            <!-- format: packageName.className -->
            <class name="tests.AmazonHomePageTest" />
            <class name="tests.AmazonSerachresultTest" />
        </classes>
    </test>

    <!--    Chrome-->
    <test name="Edge tests" preserve-order="false">
        <parameter name="browser" value="msedge"/>
        <classes>
            <!-- format: packageName.className -->
            <class name="tests.AmazonHomePageTest" />
            <class name="tests.AmazonSerachresultTest" />
        </classes>
    </test>

</suite>